meta {
  name: Iterative DNS Trace
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/dns/trace
  body: json
  auth: none
}

body:json {
  {
    "domain": "geeksforgeeks.org",
    "type": "A"
  }
}

assert {
  res.status: eq 200
  res.body.domain: eq google.com
  res.body.recordType: eq A
  res.body.status: eq NOERROR
  res.body.hops: isDefined
}
